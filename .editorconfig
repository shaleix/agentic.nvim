# Editor configuration, see http://editorconfig.org
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
# Set to false to avoid neovim + prettier race conditions (needs further investigation)
insert_final_newline = false
trim_trailing_whitespace = true
end_of_line = lf

[*.md]
trim_trailing_whitespace = false

[*.lua]
indent_size = 4

[Makefile]
indent_style = tab
